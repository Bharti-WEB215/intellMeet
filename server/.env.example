# IntellMeet Environment Configuration
# Copy this file to .env and fill in values

# ─── Server ───
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── MongoDB ───
MONGODB_URI=mongodb://localhost:27017/intellmeet

# ─── JWT Authentication ───
JWT_SECRET=intellmeet-dev-secret-change-in-production-2024
JWT_EXPIRES_IN=7d

# ─── Cloudinary (File Storage) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── OpenAI (Optional — smart fallbacks used when absent) ───
OPENAI_API_KEY=
